GROQ_API_KEY=votre_cle_groq_ici
PORT=3001
DB_PATH=sillage.db

# ── Adaptateur SIH (Proposition 3) ──────────────────────────────────────────
# Selectionnez la source de donnees patients / medicaments :
#   local  → donnees statiques src/database.js (defaut — prototype)
#   fhir   → serveur HL7 FHIR R4 (necessite FHIR_BASE_URL)
SIH_ADAPTER=local

# URL racine du serveur FHIR R4 de votre etablissement
# Exemples : https://fhir.mon-hopital.fr/fhir/R4
#            http://localhost:8080/hapi-fhir-jpaserver/fhir  (HAPI FHIR local)
FHIR_BASE_URL=

# Token d'autorisation pour le serveur FHIR (optionnel si serveur ouvert)
# Format complet : Bearer eyJhbGciOiJSUzI1NiIsInR5...
FHIR_AUTH_TOKEN=
